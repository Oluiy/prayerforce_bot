# Core Telegram Settings
TELEGRAM_TOKEN=your_token_here
ADMIN_ID=123456789  # Telegram ID of the admin

# Database (Prisma/Postgres)
DATABASE_URL=postgresql://user:password@host:port/database

# Google Sheets Integration
GSHEET_URL=https://docs.google.com/spreadsheets/d/your_sheet_id/edit?usp=sharing
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# KoraPay Integration
KORA_BASE_URL=https://api.korapay.com/merchant/api/v1
KORA_PUBLIC_KEY=pk_test_...
KORA_SECRET_KEY=sk_test_...
KORA_NOTIFICATION_URL=https://your-domain.com/webhook
KORA_REDIRECT_URL=https://t.me/YourBotName

# Counselling
COUNSELLOR_CHAT_IDS=123456789,987654321

# Google Gemini AI
GEMINI_API_KEY=your_gemini_key
